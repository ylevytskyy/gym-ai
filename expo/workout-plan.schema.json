{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/fitness/workout-plan.schema.json",
  "title": "Personalized Workout Plan",
  "description": "A personalized, period-based workout plan generated by an LLM. References exercises by id from exercises.json. Supports flexible scheduling, weekly progression, and calorie tracking at planning and execution time.",
  "type": "object",
  "required": ["schema_version", "plan"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "plan": {
      "type": "object",
      "required": ["id", "generated_at", "period", "user_profile", "weekly_structure", "days", "summary"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Plan UUID."
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 UTC timestamp."
        },
        "period": { "$ref": "#/$defs/period" },
        "user_profile": { "$ref": "#/$defs/userProfile" },
        "weekly_structure": { "$ref": "#/$defs/weeklyStructure" },
        "days": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/day" }
        },
        "summary": { "$ref": "#/$defs/summary" }
      }
    }
  },

  "$defs": {
    "date": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "time": {
      "type": "string",
      "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
      "description": "24-hour HH:MM."
    },
    "datetime": {
      "type": "string",
      "format": "date-time"
    },
    "uuid": {
      "type": "string",
      "format": "uuid"
    },

    "period": {
      "type": "object",
      "required": ["type", "start_date", "end_date"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["weekly", "monthly", "custom"] },
        "start_date": { "$ref": "#/$defs/date" },
        "end_date": { "$ref": "#/$defs/date" }
      }
    },

    "userProfile": {
      "type": "object",
      "required": ["date_of_birth", "weight_kg", "height_cm", "fitness_level", "primary_goals", "available_minutes_per_day", "limitations", "disliked_exercise_ids", "work_schedule"],
      "additionalProperties": false,
      "properties": {
        "date_of_birth": { "$ref": "#/$defs/date" },
        "weight_kg": { "type": "number", "minimum": 20, "maximum": 300 },
        "height_cm": { "type": "number", "minimum": 100, "maximum": 250 },
        "fitness_level": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "primary_goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["belly_fat", "weight_loss", "posture", "core_strength", "cardiovascular_health", "flexibility", "general_fitness", "muscle_tone", "stress_relief"]
          }
        },
        "available_minutes_per_day": { "type": "integer", "minimum": 5, "maximum": 240 },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["lower_back_injury", "lower_back_pain", "knee_injury", "knee_pain", "wrist_injury", "wrist_pain", "shoulder_injury", "shoulder_pain", "neck_injury", "elbow_injury", "ankle_injury", "hip_injury", "high_blood_pressure", "balance_issues", "vertigo", "pregnancy_late_term", "none"]
          }
        },
        "disliked_exercise_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" }
        },
        "work_schedule": {
          "type": "object",
          "required": ["work_hours", "typical_meeting_density"],
          "additionalProperties": false,
          "properties": {
            "work_hours": {
              "type": "object",
              "required": ["start", "end"],
              "additionalProperties": false,
              "properties": {
                "start": { "$ref": "#/$defs/time" },
                "end": { "$ref": "#/$defs/time" }
              }
            },
            "typical_meeting_density": { "type": "string", "enum": ["low", "medium", "high"] },
            "protected_focus_blocks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["start", "end"],
                "additionalProperties": false,
                "properties": {
                  "start": { "$ref": "#/$defs/time" },
                  "end": { "$ref": "#/$defs/time" }
                }
              }
            },
            "lunch_break": {
              "type": "object",
              "required": ["start", "end"],
              "additionalProperties": false,
              "properties": {
                "start": { "$ref": "#/$defs/time" },
                "end": { "$ref": "#/$defs/time" }
              }
            }
          }
        }
      }
    },

    "weeklyStructure": {
      "type": "object",
      "required": ["rest_days", "weekly_progression", "flexibility"],
      "additionalProperties": false,
      "properties": {
        "rest_days": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"]
          }
        },
        "weekly_progression": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["week", "intensity_multiplier"],
            "additionalProperties": false,
            "properties": {
              "week": { "type": "integer", "minimum": 1 },
              "intensity_multiplier": { "type": "number", "minimum": 0.5, "maximum": 2.0 },
              "notes": { "type": ["string", "null"] }
            }
          }
        },
        "flexibility": {
          "type": "object",
          "required": ["reschedule_policy", "max_postpones_per_session", "min_required_sessions_per_day", "buffer_minutes_between_sessions"],
          "additionalProperties": false,
          "properties": {
            "reschedule_policy": { "type": "string", "enum": ["fold_forward", "defer_to_tomorrow", "drop"] },
            "max_postpones_per_session": { "type": "integer", "minimum": 0, "maximum": 10 },
            "min_required_sessions_per_day": { "type": "integer", "minimum": 0, "maximum": 10 },
            "buffer_minutes_between_sessions": { "type": "integer", "minimum": 0, "maximum": 240 }
          }
        }
      }
    },

    "day": {
      "type": "object",
      "required": ["date", "day_of_week", "is_rest_day", "estimated_minutes_min", "estimated_minutes_max", "estimated_calories_min", "estimated_calories_max", "actual_calories_total", "completion_percentage", "sessions"],
      "additionalProperties": false,
      "properties": {
        "date": { "$ref": "#/$defs/date" },
        "day_of_week": {
          "type": "string",
          "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"]
        },
        "is_rest_day": { "type": "boolean" },
        "estimated_minutes_min": { "type": "number", "minimum": 0 },
        "estimated_minutes_max": { "type": "number", "minimum": 0 },
        "estimated_calories_min": { "type": "number", "minimum": 0 },
        "estimated_calories_max": { "type": "number", "minimum": 0 },
        "actual_calories_total": { "type": "number", "minimum": 0 },
        "completion_percentage": { "type": "number", "minimum": 0, "maximum": 100 },
        "sessions": {
          "type": "array",
          "items": { "$ref": "#/$defs/session" }
        }
      }
    },

    "session": {
      "type": "object",
      "required": ["session_id", "type", "priority", "time_window", "duration_minutes", "min_gap_from_previous_minutes", "can_split", "intensity", "estimated_calories_total", "blocks", "execution"],
      "additionalProperties": false,
      "properties": {
        "session_id": { "$ref": "#/$defs/uuid" },
        "type": { "type": "string", "enum": ["main_workout", "desk_break", "stair_cardio", "stretching"] },
        "priority": { "type": "string", "enum": ["required", "preferred", "optional"] },
        "time_window": {
          "type": "object",
          "required": ["earliest", "latest"],
          "additionalProperties": false,
          "properties": {
            "earliest": { "$ref": "#/$defs/time" },
            "latest": { "$ref": "#/$defs/time" }
          }
        },
        "duration_minutes": { "type": "number", "minimum": 0.5, "maximum": 120 },
        "min_gap_from_previous_minutes": { "type": "integer", "minimum": 0, "maximum": 480 },
        "can_split": { "type": "boolean" },
        "intensity": { "type": "string", "enum": ["low", "medium", "high"] },
        "estimated_calories_total": { "type": "number", "minimum": 0 },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/block" }
        },
        "execution": { "$ref": "#/$defs/sessionExecution" }
      }
    },

    "block": {
      "type": "object",
      "required": ["block_type", "rounds", "exercises"],
      "additionalProperties": false,
      "properties": {
        "block_type": { "type": "string", "enum": ["warmup", "main", "cooldown", "circuit"] },
        "rounds": { "type": "integer", "minimum": 1, "maximum": 20 },
        "exercises": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/plannedExercise" }
        }
      }
    },

    "plannedExercise": {
      "type": "object",
      "required": ["exercise_id", "order", "sets", "amount", "unit", "rest_seconds", "estimated_calories", "execution"],
      "additionalProperties": false,
      "properties": {
        "exercise_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "References exercises[].id in exercises.json. Cross-file existence is enforced by the prompt and validated by the app at runtime."
        },
        "order": { "type": "integer", "minimum": 1 },
        "sets": { "type": "integer", "minimum": 1, "maximum": 20 },
        "amount": { "type": "integer", "minimum": 1, "maximum": 600 },
        "unit": { "type": "string", "enum": ["reps", "seconds", "meters_climbed"] },
        "rest_seconds": { "type": "integer", "minimum": 0, "maximum": 300 },
        "notes": { "type": ["string", "null"] },
        "estimated_calories": { "type": "number", "minimum": 0 },
        "execution": { "$ref": "#/$defs/exerciseExecution" }
      }
    },

    "exerciseExecution": {
      "type": "object",
      "required": ["status", "actual_sets_completed", "actual_amount_per_set", "actual_work_seconds", "perceived_effort_rpe", "actual_calories", "completed_at"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["pending", "completed", "partial", "skipped"] },
        "actual_sets_completed": { "type": "integer", "minimum": 0 },
        "actual_amount_per_set": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "actual_work_seconds": { "type": "number", "minimum": 0 },
        "perceived_effort_rpe": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 1, "maximum": 10 }
          ]
        },
        "actual_calories": { "type": "number", "minimum": 0 },
        "completed_at": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/datetime" }
          ]
        }
      }
    },

    "sessionExecution": {
      "type": "object",
      "required": ["status", "actual_start_time", "actual_duration_minutes", "actual_calories_total", "completion_percentage"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["pending", "completed", "partial", "skipped"] },
        "actual_start_time": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/datetime" }
          ]
        },
        "actual_duration_minutes": { "type": "number", "minimum": 0 },
        "actual_calories_total": { "type": "number", "minimum": 0 },
        "completion_percentage": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },

    "summary": {
      "type": "object",
      "required": ["estimated_period_calories_min", "estimated_period_calories_max", "estimated_average_daily_calories", "actual_period_calories", "calorie_model_version"],
      "additionalProperties": false,
      "properties": {
        "estimated_period_calories_min": { "type": "number", "minimum": 0 },
        "estimated_period_calories_max": { "type": "number", "minimum": 0 },
        "estimated_average_daily_calories": { "type": "number", "minimum": 0 },
        "actual_period_calories": { "type": "number", "minimum": 0 },
        "calorie_model_version": { "type": "string", "const": "1.0.0" }
      }
    }
  }
}
